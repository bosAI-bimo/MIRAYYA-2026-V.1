# Database PostgreSQL (Supabase)
DATABASE_URL="postgresql://postgres.your_id:your_password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres.your_id:your_password@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require"

# Better Auth
BETTER_AUTH_SECRET="change-me-min-32-chars-for-production"
BETTER_AUTH_URL="http://localhost:5000"

# AI Insights
GEMINI_API_KEY="your-gemini-api-key"

# Frontend Integration
FRONTEND_URL="http://localhost:3000"

# Cron Job Secret
CRON_SECRET="change-me-random-secret"

# Supabase Storage & Services
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

NODE_ENV="development"
