# Database PostgreSQL (Supabase)
DATABASE_URL="postgresql://your_user:your_password@your-host.supabase.com:6543/postgres?sslmode=require"
DIRECT_URL="postgresql://your_user:your_password@your-host.supabase.com:5432/postgres?sslmode=require"

# Better Auth
BETTER_AUTH_SECRET=change-this-to-a-secure-random-string
BETTER_AUTH_URL=http://localhost:5000

# Supabase Storage (for file uploads)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
